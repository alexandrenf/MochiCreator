# Your Mochi API key — get it from https://app.mochi.cards/settings (API section)
MOCHI_API_KEY=

# A secret token you choose — Claude.ai will send this as Bearer token to authenticate
# Generate one with: openssl rand -hex 32
MCP_AUTH_TOKEN=

# Secret token that ClaudeReminders expects for the /notify endpoint
# Must match NOTIFY_TOKEN set on the ClaudeReminders Fly.io app
CLAUDEREMINDERS_NOTIFY_TOKEN=

# Override ClaudeReminders base URL (optional, defaults to https://yoururl.fly.dev)
# CLAUDEREMINDERS_URL=https://yoururl.fly.dev

# Port (optional, defaults to 8080)
PORT=8080
